---
# source: bmo/baremetalhost-values/values.yaml.j2
data:
  bmc_credentials:
    username: {{ cifmw_baremetal_hosts["controller-0"].username | b64encode }}
    password: {{ cifmw_baremetal_hosts["controller-0"].password | b64encode }}

{% for host in cifmw_networking_env_definition.instances.keys() if host is match('^(leaf0|leaf1).*') %}
  {{ host | replace('-' + cifmw_run_id, '') }}:
    bmc:
      address: {{ cifmw_baremetal_hosts[host].connection }}
      credentialsName: bmc-secret
    bootMACAddress: {{ cifmw_baremetal_hosts[host].nics[0].mac }}
    labels:
      app: openstack
      nodeset: {{ host | split('-') | first }}
    name: {{ host }}
    rootDeviceHints:
      deviceName: /dev/sda
{% endfor %}
